<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yr.system.mapper.SsoClientMapper">

    <resultMap id="SsoClientResult" type="com.yr.common.core.domain.entity.SsoClient">
        <id property="clientId" column="client_id"/>
        <result property="clientCode" column="client_code"/>
        <result property="clientName" column="client_name"/>
        <result property="clientSecret" column="client_secret"/>
        <result property="redirectUris" column="redirect_uris"/>
        <result property="allowPasswordLogin" column="allow_password_login"/>
        <result property="allowWxworkLogin" column="allow_wxwork_login"/>
        <result property="syncEnabled" column="sync_enabled"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

</mapper>
