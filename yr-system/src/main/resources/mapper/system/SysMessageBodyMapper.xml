<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yr.system.mapper.SysMessageBodyMapper">

    <!-- PopoY: 显式标注 TIMESTAMP 映射，配合 LocalDateTime 收口消息时间类型。 -->
    <resultMap id="BaseResultMessageBodyMap" type="com.yr.system.domain.entity.SysMessageBody">
        <id column="id" property="id"/>
        <result column="msg_title" property="msgTitle"/>
        <result column="msg_name" property="msgName"/>
        <result column="msg_body" property="msgBody"/>
        <result column="send_type" property="sendType"/>
        <result column="create_at" property="createAt" jdbcType="TIMESTAMP"/>
        <result column="update_at" property="updateAt" jdbcType="TIMESTAMP"/>
        <result column="status" property="status"/>
        <result column="create_by" property="createBy"/>
        <result column="update_by" property="updateBy"/>
        <result column="remark" property="remark"/>
        <result column="msg_from" property="msgFrom"/>
        <result column="object_version_number" property="objectVersionNumber"/>
        <result column="url" property="url"/>
        <result column="url_param" property="urlParam"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, msg_title,msg_from,url,url_param, msg_name, msg_body, send_type, create_at, update_at, status, create_by, update_by, remark, object_version_number
    </sql>
    <select id="pageList" resultMap="BaseResultMessageBodyMap">
        select
        <include refid="Base_Column_List"/>
        from sys_message_body
        <where>
            <if test="null != request">
                <if test="null != request.title and '' != request.title">
                    and msg_title like concat('%',#{request.title},'%')
                </if>

                <if test="null != request.name and '' != request.name">
                    and msg_name like concat('%',#{request.name},'%')
                </if>

                <if test="null != request.status and '' != request.status">
                    and status = #{request.status}
                </if>

                <if test="null != request.sendType and '' != request.sendType">
                    and send_type = #{request.sendType}
                </if>
            </if>
        </where>
        order by create_at desc
    </select>

    <select id="findById" resultMap="BaseResultMessageBodyMap">
        select
        <include refid="Base_Column_List"/>
        from
        sys_message_body
        where
        id = #{id}
    </select>

</mapper>
